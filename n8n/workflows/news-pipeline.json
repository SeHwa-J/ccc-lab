            },
            {
              "name": "content-type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"claude-haiku-4-5-20251001\",\n  \"max_tokens\": 300,\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"다음 뉴스 기사가 CX(고객경험), CS(고객서비스), CSM(고객성공), CRM 업무 담당자에게 실무적으로 유용한지 판단해줘.\\n\\n제목: 어도비, CX 엔터프라이즈 공개…고객 경험 오케스트레이션 비전 재정의 - 전자신문\\n출처: 전자신문\\n\\nJSON만 응답 (다른 텍스트 없이):\\n{\\\"relevant\\\": true 또는 false, \\\"score\\\": 1~10, \\\"summary\\\": \\\"한 줄 요약 (50자 이내)\\\"}\"\n    }\n  ]\n}",
        "options": {
          "timeout": 30000
        }
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [
        1360,
        0
      ],
      "id": "66d549ec-0a6f-4ceb-bf9a-9dfa58f3ee33",
      "name": "Claude 관련성 판단",
      "executeOnce": false
    },
    {
      "parameters": {
        "jsCode": "function normalize(title) {\n  return title\n    .replace(/\\s*-\\s*.+$/, '')\n    .replace(/[^\\w가-힣]/g, '')\n    .toLowerCase();\n}\n\nfunction getKeywords(title) {\n  const normalized = normalize(title);\n  const chunks = [];\n  for (let i = 0; i < normalized.length - 3; i++) {\n    chunks.push(normalized.substring(i, i + 4));\n  }\n  return new Set(chunks);\n}\n\nfunction similarity(a, b) {\n  const setA = getKeywords(a);\n  const setB = getKeywords(b);\n  if (setA.size === 0 || setB.size === 0) return 0;\n  const intersection = [...setA].filter(x => setB.has(x)).length;\n  const union = new Set([...setA, ...setB]).size;\n  return intersection / union;\n}\n\nconst all = $input.all().map(i => i.json);\nconst unique = [];\n\nfor (const article of all) {\n  let isDuplicate = false;\n  for (const existing of unique) {\n    if (similarity(article.title, existing.title) > 0.5) {\n      isDuplicate = true;\n      break;\n    }\n  }\n  if (!isDuplicate) {\n    unique.push(article);\n  }\n}\n\nreturn unique.map(item => ({ json: item }));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
